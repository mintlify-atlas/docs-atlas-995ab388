  "keyFeatures": [
    "Secure by default with granular permissions system",
    "Native TypeScript support without configuration",
    "Built-in tooling (formatter, linter, test runner, bundler)",
    "Web standards compatibility (fetch, WebSocket, streams)",
    "Node.js and npm compatibility",
    "Single executable with no dependencies",
    "Built-in package manager with JSR and npm support",
    "WebAssembly and FFI support",
    "Deno KV for built-in key-value database",
    "HTTP server with Deno.serve API",
    "Built-in benchmarking and code coverage",
    "Compile to standalone executables"
  ],
  "publicApiSurface": [
    "deno run - Execute JavaScript/TypeScript programs",
    "deno test - Run tests",
    "deno bench - Run benchmarks",
    "deno fmt - Format source code",
    "deno lint - Lint source code",
    "deno compile - Compile to standalone executable",
    "deno bundle - Bundle module and dependencies",
    "deno doc - Generate documentation",
    "deno info - Show module information",
    "deno cache - Cache dependencies",
    "deno check - Type-check files",
    "deno coverage - Generate code coverage",
    "deno init - Initialize a new project",
    "deno install - Install script as executable",
    "deno uninstall - Uninstall executable",
    "deno repl - Start interactive REPL",
    "deno serve - Run HTTP server",
    "deno task - Run task from config",
    "deno upgrade - Upgrade Deno installation",
    "deno jupyter - Jupyter kernel support",
    "deno publish - Publish to JSR",
    "deno add - Add dependencies",
    "deno remove - Remove dependencies",
    "Deno.serve() - HTTP server API",
    "Deno.readFile() - File system operations",
    "Deno.connect() - Network operations",
    "Deno.Command() - Process management",
    "Deno.KV - Key-value database",
    "Deno.cron() - Scheduled tasks",
    "Deno.test() - Testing API",
    "Deno.bench() - Benchmarking API"
  ]
